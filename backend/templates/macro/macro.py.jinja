{# creation d'un generateur de route #}

{% macro route_path(relations, classe) -%}
    {%- set relation = relations | selectattr("cible", "equalto", classe.nom) | list -%}
    {%- set nom = classe.nom | lower -%}

    {%- if relation -%}
        {%- set parent = relation[0].source | lower -%}
        {{- "/" + parent + "/<int:id>/" + nom -}}
    {%- else -%}
        {{- "/" -}}
    {%- endif -%}
{%- endmacro %}



{% macro genere_param_id(relations, classe) -%}
    {%- set relation = relations | selectattr("cible", "equalto", classe.nom) | list -%}
    {{- "id" if relation else "" -}}
{%- endmacro %}


{% macro ressource_lie(relations_cible, blueprint, schema) %}
{% for rel in relations_cible %}
{% set source_id = rel.source | lower ~ "_id" %}
{% set source_min = rel.source | lower %}
{% set cible_min = rel.cible | lower %}
@{{ blueprint }}.post("/{{ source_min }}/<int:id>/{{ cible_min }}")
def creer_ress_{{ cible_min }}(id):
    with get_db() as db:
        try:
            {{ source_id }} = db.query({{ rel.source }}).filter({{ rel.source }}.id == id).first()
            if not {{ source_id }}:
                abort(404, description="Ressource introuvale (macro)")

            data = get_json_or_400()
            data["{{ source_id }}"] = id
            {{ nom }} = {{ schemaOne }}.load(data, session=db)
            db.add({{ nom }})
            db.commit()
            return reponse_json(data={{ schemaOne }}.dump({{ nom }}), status=201)
        except ValidationError as err:
            abort(400, description=str(err.messages))    
{% endfor %}
{% endmacro %}