    {{ genere_user_id_jwt(v.protege, use_jwt) }}
    with get_db() as db:
        try:
            data = get_json_or_400()
            {{ genere_logique_jwt_user(use_jwt, v.classe) | indent(12, true) }}
            {{ genere_use_session(use_session, relations_cible) | indent(12, true) }}
