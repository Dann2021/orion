{% macro genere_logique_update(schema_one, nom) %}
try:
    data = get_json_or_400()
    updated = {{ schema_one }}.load(data, instance={{ nom }}, session=db, partial=True)
    db.commit()
    return reponse_json(data={{ schema_one }}.dump(updated))
except ValidationError as err:
    abort(400, description=str(err.messages))
{% endmacro %}

