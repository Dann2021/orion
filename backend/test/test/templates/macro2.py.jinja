{# Toolkit pour get_all #}
{% macro genere_filtre_et_pagination(limit, offset) %}
{{ limit }} = min(request.args.get("{{ limit }}", 20, type=int), 100)
{{ offset }} = request.args.get("{{ offset }}", 0, type=int)
{% endmacro %}

{% macro genere_database_query(classe) %}
query = db.query({{ classe }})
{% endmacro %}

{% macro genere_params_variable(model) %}
{% set classe = model.nom %}
{# filtre dynamiques #}
{% for attr in model.attributs %}
if "{{ attr.nom }}" in request.args:
    query = query.filter({{ classe }}.{{ attr.nom }} == request.args.get("{{ attr.nom }}"))
{% endfor %}
{% endmacro %}

{%- macro genere_params_variable_new(classe) %}
filtres = request.args.to_dict()

filtres.pop("limit", None)
filtres.pop("offset", None)
sort = filtres.pop("sort", None)

# on parcourt le dictionnaire de filtres
for cle, valeur in filtres.items():
    # on verifie si la classe contient un attribut 
    if hasattr({{ classe }}, cle):
        colonne = getattr({{ classe }}, cle)
        if isinstance(valeur, str):
            if valeur.lower() == "true":
                valeur = True
            elif valeur.lower() == "false":
                valeur = False
        query = query.filter(colonne == valeur)

# tri dynamique
if sort:
    desc = sort.startswith("-")
    champ = sort.lstrip("-")
    
    if hasattr({{ classe }}, champ):
        colonne = getattr({{ classe }}, champ)
        query = query.order_by(colonne.desc() if desc else colonne)
{%- endmacro -%}

{% macro genere_total_and_item(limit, offset) %}
total = query.count()
items = query.offset({{ offset }}).limit({{ limit }}).all()
{% endmacro -%}

{%- macro genere_reponse(schema_many) %}
return reponse_json(
    data={{ schema_many }}.dump(items), 
    meta={
        "total":total, 
        "limit":limit, 
        "offset":offset
    })
{% endmacro -%}


