{# Générateur de logique metier api #}

{# Pour use_jwt et model.nom == "User" #}
{%- macro genere_logique_jwt_user(use_jwt, classe) %}
{%- if use_jwt and classe == "User" %}
password_hashed = bcrypt.generate_password_hash(data['password']).decode("utf-8")
data['password'] = password_hashed
{% endif -%}
{% endmacro -%}

{# Pour use_session #}
{%- macro genere_use_session(use_session, relations_cible) %}
{%- if use_session %}
{%- for rel in relations_cible %}
{% set source_id = rel.source | lower ~ "_id" %}
{{ source_id }} = session.get("{{ source_id }}")
if not {{ source_id }}:
    abort(400)
{#data["{{ source_id }}"] = {{ source_id }}  #}
{% endfor -%}
{% endif -%}
{% endmacro -%}

{# Pour protege #}
{%- macro genere_protege(protege, use_jwt) %}
{% if protege and use_jwt %}
data['user_id'] = user_id
{% endif %}
{% endmacro -%}

{# pour pas use (session et jwt) #}
{%- macro genere_pas_session_jwt(relations_cible, use_session, use_jwt) %}
{%- if not use_session and not use_jwt %}
{%- for rel in relations_cible %}
{% set source = rel.source | lower %}
{{ source }} = db.get({{ rel.source }}, id)
if not {{ source }}:
    abort(404, description="{{ source }} introuvable")     
{% endfor -%}
{% endif -%}
{% endmacro -%}

{# Pour use jwt et relations #}
{%- macro genere_use_jwt_relations(use_jwt, relations_cible) %}
{%- if use_jwt %}
{%- for rel in relations_cible %}
{% set source = rel.source | lower %}
{{ source }} = db.get({{ rel.source }}, id)
if not {{ source }}:
    abort(404, description="{{ source }} introuvable")
{% endfor -%}
{% endif -%}
{% endmacro -%}

{# Pour creer une instance #}
{%- macro genere_logique_instance(nom, schema, relations_cible ) %}
{%- for rel in relations_cible %}
{% set source_id = rel.source | lower ~ "_id"%}
{#{- nom }}.{{ source_id }} = id #}
data["{{ source_id }}"] = id
{%- endfor %}
{{ nom }} = {{ schema }}.load(data, session=db)
{% endmacro %}

{% macro genere_logique_instance2(nom, schema, relations_cible, use_session ) %}
{%- for rel in relations_cible %}
{% set source_id = rel.source | lower ~ "_id" %}

{% if use_session %}
data["{{ source_id }}"] = {{ source_id }}
{% else %}
data["{{ source_id }}"] = id
{% endif %}

{%- endfor %}

{{ nom }} = {{ schema }}.load(data, session=db)
{% endmacro %}

{# Pour dans la base de données #}
{%- macro genere_add_to_database(nom) %}
db.add({{ nom }})
db.commit() 
{% endmacro -%}

{# Pour une use_session et relations source #}
{% macro genere_session_source(use_session, relations_source, nom) %}
{%- if use_session %}
{%- for rel in relations_source %}
{% set source_id = rel.source | lower ~ "_id"%}
session["{{ source_id }}"] = {{ nom }}.id
{% endfor -%}
{% endif -%}
{% endmacro %}

{% macro check_relations(relations_cible) %}
{% for rel in relations_cible %}
{% set source = rel.source | lower %}
{{ source }} = db.get({{ rel.source }}, id)
if not {{ source }}:
    abort(404, description="{{ source }} introuvable")
{% endfor %}
{% endmacro %}

{% macro genere_user_id_jwt(protege, use_jwt) %}
{% if protege and use_jwt %}
    user_id = get_jwt_identity()
{% endif -%}
{% endmacro %}

{# Générateur de route pour post #}
{% macro create_route_block(model, relations, use_jwt, use_session) %}
{%- set relations_source = relations | selectattr("source", "equalto", model["nom"]) | list -%}
{%- set relations_cible = relations | selectattr("cible", "equalto", model["nom"]) | list -%}
{%- set est_protege = model.protege is defined and model.protege -%}
{# definition des variables #}
{% set v = namespace() -%}
{{ genere_variable(model, v) -}}

{# utilisation du schema #}
{{ v.schemaOne }} = {{ v.nomSchema }}()
{{ v.schemaMany }} = {{ v.nomSchema }}(many=True)

{# utilisation du blueprint #}
@{{ v.blueprint }}.post("{{ route_path2(relations, model, use_session) }}")
{% if v.protege and use_jwt -%}
@jwt_required()
{% endif -%}
def creer_{{ v.nom }}({{ genere_param_id2(relations, model, use_session) }}):
    {{ genere_user_id_jwt(v.protege, use_jwt) }}
    with get_db() as db:
        try:
            data = get_json_or_400()
            {{ genere_logique_jwt_user(use_jwt, v.classe) | indent(12, true) }}
            {#{- avec_relation(relations, v.classe) | indent(12, true) -}#}
            {{ genere_use_session(use_session, relations_cible) | indent(12, true) }}
            {{ genere_protege(v.protege, use_jwt) | indent(12, true) }}
            {#{ check_relations(relations_cible) | indent(12, true) }#}
            {#{ genere_pas_session_jwt(relations_cible, use_session, use_jwt) | indent(12, true) } ici #}
            {#{ genere_use_jwt_relations(use_jwt, relations_cible) | indent(12, true) } ici #}
            {{ genere_logique_instance2(v.nom, v.schemaOne, relations_cible, use_session) | indent(12, true) }}
            {#- utilisation du schéma #}
            {{ genere_add_to_database(v.nom) | indent(12, true) }}
            {{ genere_session_source(use_session, relations_source, v.nom) | indent(12, true) }}
            return reponse_json(data={{ v.schemaOne }}.dump({{ v.nom }}), status=201)
        except ValidationError as err:
            abort(400, description=str(err.messages))
{% endmacro %}










