if not {{ source_id }}:
    abort(404, description="Ressource introuvable")
{%- endif -%}
{%- endfor -%}
{%- endmacro -%}

{# Générateur d'import #}
{%- macro genere_import(model, relations, use_session, use_jwt) -%}
{% set v = namespace() -%}
{{ genere_variable(model, v) -}}
{%- set est_protege = model.protege is defined and model.protege -%}
{%- set relations_source = relations | selectattr("source", "equalto", model["nom"]) | list -%}
{%- set relations_cible = relations | selectattr("cible", "equalto", model["nom"]) | list -%}
{# import des package de base toujours utilisé dans une route api #}
from flask import Blueprint, request, abort
from utils.utils import reponse_json, get_json_or_400
from database import get_db
from marshmallow import ValidationError
from modeles.models import {{ v.classe -}}

{# import du schema #}
from schemas.{{ v.nomFichierSchema }} import {{ v.nomSchema -}}

