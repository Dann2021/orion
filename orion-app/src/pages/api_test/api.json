[
    {
        "method": "POST",
        "path": "/api/ressources",
        "description": "Route pour creer une nouvelle ressource",
        "request": {
            "body": {"nom": "string", "description": "string"}
        },
        "response": {
            "status": 201,
            "body": {"message": "Ressource créée avec succès"}
        }

    }, 
    {
        "method": "GET",
        "path": "/api/ressources/",
        "description": "Route pour recuperer toutes les ressources",
        "response": {
            "status": 200,
            "body": {
                "ressources": [
                    {"id": 1, "nom": "ressource1", "description": "Description de la ressource 1"},
                    {"id": 2, "nom": "ressource2", "description": "Description de la ressource 2"}
                ]
            }
        }
    },
    {
        "method": "GET",
        "path": "/api/ressources/{id}",
        "description": "Route pour recuperer une ressource par ID",
        "response": {
            "status": 200,
            "body": {"id": 1, "nom": "ressource1", "description": "Description de la ressource 1"}
        }
    },
   
    {
        "method": "PUT",
        "path": "/api/ressources/{id}",
        "description": "Route pour mettre a jour une ressource par ID",
        "request": {
            "body": {"nom": "string", "description": "string"}
        },
        "response": {
            "status": 200,
            "body": {"message": "Ressource mise a jour avec succes"}
        }
    },
                
    
    
    {
        "method": "DELETE",
        "path": "/api/ressources/{id}",
        "description": "Route pour supprimer une ressource par ID",
        "response": {
            "status": 204,
            "body": {
                "message": "Ressource supprimee avec succes"
            }
        }
    }
]